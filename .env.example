# Joshi Rankings API — Environment Variables
PORT=8080
DB_PATH=joshi.db
SCRAPER_INTERVAL_HOURS=24
SCRAPER_RATE_LIMIT_MS=3000
GIN_MODE=debug
# API key — generate a strong random key: openssl rand -hex 32
API_KEY=
# CORS allowed origins (comma-separated). Default: http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080
